{
  "name": "reditor",
  "version": "0.1.0",
  "description": "Edit files from your server in the browser.",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "bin": {
    "reditor": "dist/bin.js"
  },
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "build:web": "cd web && npm run build",
    "build:web:watch": "cd web && npm run build:watch",
    "prebuild:all": "node -e \"require('fs').rmSync('dist/web', {recursive:true, force:true})\"",
    "build:all": "npm run build:web && npm run build",
    "postbuild": "chmod +x dist/bin.js",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:web": "cd web && npm test",
    "typecheck:web": "cd web && npm run typecheck",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "spell": "cspell lint --no-progress",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "cspell lint --no-progress --no-must-use-config",
      "prettier --check"
    ],
    "*.{md,html}": [
      "cspell lint --no-progress --no-must-use-config"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/selfsigned": "^2.0.4",
    "@types/supertest": "^7.2.0",
    "cspell": "^9.7.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.3.3",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "selfsigned": "^5.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "winston": "^3.19.0"
  }
}
