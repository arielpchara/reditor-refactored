# file — reditor HTTP scenarios
# Base URL: update @host and @port to match your running server
# Use the REST Client VS Code extension to run these requests.
#
# Start server:
#   No security:  npx reditor serve --root /path/to/your/files
#   With security: npx reditor serve --enable-security --root /path/to/your/files
#
# When security is enabled, exchange an OTP for a token first (see auth.http),
# then paste the token into @token below.

@host = localhost
@port = 3000
@baseUrl = https://{{host}}:{{port}}
@token = <paste JWT token here>

### Read a file — success (no security)
# Expected: 200 raw text content
GET {{baseUrl}}/file?path=README.md

###

### Read a file — success (with JWT)
# Expected: 200 raw text content
GET {{baseUrl}}/file?path=README.md
Authorization: Bearer {{token}}

###

### Read a file — missing path parameter
# Expected: 400 {"error":"Query parameter \"path\" is required"}
GET {{baseUrl}}/file

###

### Read a file — file not found
# Expected: 404 {"error":"File not found: nonexistent.txt"}
GET {{baseUrl}}/file?path=nonexistent.txt

###

### Read a file — path traversal attempt
# Expected: 403 {"error":"Access denied: path traversal detected"}
GET {{baseUrl}}/file?path=../../etc/passwd

###

### Read a file — non-ASCII (binary) file
# Expected: 422 {"error":"File is not ASCII-encoded"}
GET {{baseUrl}}/file?path=somefile.bin

###

### Read a file — file too large for editor
# Expected: 413 {"error":"File too large for editor (... bytes, max 524288 bytes)"}
GET {{baseUrl}}/file?path=large-file.log

###

### Read a file — no auth token when security is enabled
# Expected: 401 {"error":"Authorization header missing or malformed"}
# (start server with --enable-security and omit the Authorization header)
GET {{baseUrl}}/file?path=README.md

###

### Read a file — invalid JWT token
# Expected: 401 {"error":"Invalid or expired token"}
GET {{baseUrl}}/file?path=README.md
Authorization: Bearer invalid.token.here
