# file — reditor HTTP scenarios
# Base URL: update @host and @port to match your running server
# Use the REST Client VS Code extension to run these requests.
#
# Start server with a file:
#   No security:  npx reditor serve /path/to/your/file.ts
#   With security: npx reditor serve /path/to/your/file.ts --enable-security
#
# When security is enabled, exchange an OTP for a token first (see auth.http),
# then paste the token into @token below.

@host = localhost
@port = 3000
@baseUrl = https://{{host}}:{{port}}
@token = eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJyZWRpdG9yIiwiaWF0IjoxNzczMzQ5Mzc3LCJleHAiOjE3NzM4NDkzNzd9.ak7-DImSxLdjgA6yX4XZ7zmj42gE3UJ_jufoKTAc4lbalXyQef26_F7cRyo04SiVXInl8ZlnanX0repTE6tpffBunZsBm7BaI3c4Wav3vKhOszTDrmnYoOwQeiW__RT2f3KtxjiqKGmDVxvO2uhFUr9u47JFgJyOcPdNsJFvw4SThXUnSYFwjeyNB8Nc_7TYnjgllCgrUAAvvkSJa3SStE-9UEExhgFguQv9Qs_iD1twZ-wuOrfNtMsJ2MztkmpjIiT2x7xjP4cthq_gKGIW8mvl2AaPO0zmkBhGbVDIEhfkfCphu-v8_U_YNwnxsSgPVJpoIJjrvka1zQwv9bhZSg

### Read the configured file — success (no security)
# Expected: 200 raw text content of the file passed at startup
GET {{baseUrl}}/file

###

### Read the configured file — success (with JWT)
# Expected: 200 raw text content
GET {{baseUrl}}/file
Authorization: Bearer {{token}}

###

### Read the configured file — no longer exists on disk
# Expected: 404 {"error":"File not found: /path/to/file"}
# (delete the file from disk while the server is running to reproduce)
GET {{baseUrl}}/file

###

### Read the configured file — not ASCII
# Expected: 422 {"error":"File is not ASCII-encoded"}
# (start server with: npx reditor serve /path/to/binary.bin)
GET {{baseUrl}}/file

###

### Read the configured file — too large for editor (>512 KB)
# Expected: 413 {"error":"File too large for editor (... bytes, max 524288 bytes)"}
# (start server with: npx reditor serve /path/to/large-file.log)
GET {{baseUrl}}/file

###

### Read the configured file — no auth token when security is enabled
# Expected: 401 {"error":"Authorization header missing or malformed"}
GET {{baseUrl}}/file

###

### Read the configured file — invalid JWT token
# Expected: 401 {"error":"Invalid or expired token"}
GET {{baseUrl}}/file
Authorization: Bearer invalid.token.here
