# file — reditor HTTP scenarios
# Base URL: update @host and @port to match your running server
# Use the REST Client VS Code extension to run these requests.
#
# Start server with a file:
#   With security (default): npx reditor serve /path/to/your/file.ts
#   No security:             npx reditor serve /path/to/your/file.ts --force-disable-security
#
# When security is enabled, exchange an OTP for a token first (see auth.http),
# then paste the token into @token below.

@host = localhost
@port = 3000
@baseUrl = https://{{host}}:{{port}}
@token = <paste JWT token here>

### GET /file-meta — filename info (no security)
# Expected: 200 { "filename": "file.ts", "fullpath": "/abs/path/to/file.ts", "size": 1234, "type": "text/typescript", "hasShebang": false }
GET {{baseUrl}}/file-meta

###

### GET /file-meta — with JWT (security enabled)
# Expected: 200 { "filename": "file.ts", "fullpath": "/abs/path/to/file.ts", "size": 1234, "type": "text/typescript", "hasShebang": false }
GET {{baseUrl}}/file-meta
Authorization: Bearer {{token}}

###

### GET /file — read file content (no security)
# Expected: 200 raw text content of the file passed at startup
GET {{baseUrl}}/file

###

### GET /file — read file content (with JWT)
# Expected: 200 raw text content
GET {{baseUrl}}/file
Authorization: Bearer {{token}}

###

### PUT /file — save edited content (no security)
# Expected: 204 No Content
PUT {{baseUrl}}/file
Content-Type: application/json

{
  "content": "// edited content\nconsole.log('hello');\n"
}

###

### PUT /file — save edited content (with JWT)
# Expected: 204 No Content
PUT {{baseUrl}}/file
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "content": "// edited content\nconsole.log('hello');\n"
}

###

### PUT /file — content too large (>512 KB)
# Expected: 413 {"error":"Content too large (... bytes, max 524288 bytes)"}
# (send a body with content larger than 512 KB to reproduce)
PUT {{baseUrl}}/file
Content-Type: application/json

{
  "content": "<512 KB+ string here>"
}

###

### PUT /file — missing content field
# Expected: 400 {"error":"Request body must contain a \"content\" string field"}
PUT {{baseUrl}}/file
Content-Type: application/json

{}

###

### GET /file — no auth token when security is enabled
# Expected: 401 {"error":"Authorization header missing or malformed"}
GET {{baseUrl}}/file

###

### GET /file — invalid JWT token
# Expected: 401 {"error":"Invalid or expired token"}
GET {{baseUrl}}/file
Authorization: Bearer invalid.token.here
