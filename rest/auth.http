# auth — reditor HTTP scenarios
# Base URL: update @host and @port to match your running server
# Use the REST Client VS Code extension to run these requests.
#
# Security is ENABLED by default. Start the server and note the OTP printed to stdout:
#   npx reditor serve <file>
#
# For testing with a predictable OTP (⚠️ TEST ONLY):
#   npx reditor serve <file> --force-otp 123
#
# To disable security entirely (⚠️ DANGER — no auth, anyone can read the file):
#   npx reditor serve <file> --force-disable-security

@host = localhost
@port = 3000
@baseUrl = https://{{host}}:{{port}}

# After a successful exchange, paste the returned token here to use authenticated endpoints:
@token = <paste JWT token here>

### Exchange OTP for JWT — valid OTP
# Expected: 200 {"token":"<JWT>","expiresIn":300}
POST {{baseUrl}}/auth/exchange-token
Content-Type: application/json

{
  "otp": "123"
}

###

### Exchange OTP for JWT — forced OTP (⚠️ TEST ONLY — requires --force-otp 123)
# Expected: 200 {"token":"<JWT>","expiresIn":300}
POST {{baseUrl}}/auth/exchange-token
Content-Type: application/json

{
  "otp": "123"
}

###

### Exchange OTP for JWT — wrong OTP
# Expected: 401 {"error":"Invalid OTP"}
POST {{baseUrl}}/auth/exchange-token
Content-Type: application/json

{
  "otp": "000000"
}

###

### Exchange OTP for JWT — missing OTP field
# Expected: 401 {"error":"Invalid OTP"}
POST {{baseUrl}}/auth/exchange-token
Content-Type: application/json

{}

###

### Exchange OTP for JWT — security disabled
# Expected: 403 {"error":"Security is not enabled"}
# (start server with --force-disable-security to reproduce)
POST {{baseUrl}}/auth/exchange-token
Content-Type: application/json

{
  "otp": "123456"
}
