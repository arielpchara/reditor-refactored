#!/bin/sh
set -e

echo "🔍 [pre-commit] Running spell check and format check on staged files..."
npx lint-staged

echo "🔷 [pre-commit] Running TypeScript syntax check..."
npm run typecheck

echo "🔷 [pre-commit] Running TypeScript syntax check (web)..."
npm run typecheck:web

echo "🧪 [pre-commit] Running unit tests..."
npm test

echo "🧪 [pre-commit] Running unit tests (web)..."
npm run test:web

echo "✅ [pre-commit] All checks passed."
